# ==============================================================================
.vscode/
!.vscode/settings.json.example
.idea/
*.iml
*.suo
*.user
*.sln.docstates
.project
.cproject
.settings/
.ccls-cache/
.clangd/
compile_commands.json
.cache/

# Vim / Emacs / nano
*~
*.swp
*.swo
*.swn
.*.swp
.*.swo
Session.vim
.netrwhist
\#*\#
.\#*

# ==============================================================================
# OS files
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# ==============================================================================
# Logs, temp, backups
# ==============================================================================
*.log
logs/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
nohup.out

