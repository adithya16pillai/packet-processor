# ==============================================================================
# Build artifacts
# ==============================================================================
build/
pktproc
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.elf
*.map
*.lst
*.bin

# ==============================================================================
# Test / coverage / sanitizer output
# ==============================================================================
*.gcno
*.gcda
*.gcov
coverage/
coverage.info
coverage.xml
lcov.info
*.profraw
*.profdata
callgrind.out.*
cachegrind.out.*
massif.out.*
valgrind-*.log
vgcore.*
core
core.*
*.core

# ==============================================================================
# Captured traffic — CAN CONTAIN CREDENTIALS, SESSION COOKIES, PII
# Never commit pcap/pcapng captures. Add specific intentional fixtures by path.
# ==============================================================================
*.pcap
*.pcapng
*.cap
*.dump
captures/
dumps/

# ==============================================================================
# Secrets & credentials — never commit these
# ==============================================================================
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.env
secrets
secrets/
secrets.*
credentials
credentials.*
.credentials
.credentials/
auth.json
service-account*.json
*-secrets.yaml
*-secrets.yml
*_secret.*
*.secret

# Cloud provider configs
.aws/
.gcloud/
.azure/
.kube/config
kubeconfig
*.kubeconfig

# Cryptographic material
*.pem
*.key
*.keystore
*.jks
*.p12
*.pfx
*.der
*.cer
*.crt
*.csr
*.gpg
*.asc
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub
id_ecdsa
id_ecdsa.pub
id_ed25519
id_ed25519.pub
*.ppk
known_hosts
authorized_keys

# API tokens commonly auto-generated by tooling
.npmrc
.pypirc
.netrc
.git-credentials
.ssh/

# Database dumps (often contain PII / secrets)
*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.db

